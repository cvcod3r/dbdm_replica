<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.dbms.dao.LicenseDao">

    <!-- 通用查询映射结果 -->
    <resultMap id="BaseResultMap" type="com.dbms.entity.LicenseEntity">
        <id column="license_id" property="licenseId" />
        <result column="version" property="version" />
        <result column="createtime" property="createtime" />
        <result column="license_name" property="licenseName" />
        <result column="company" property="company" />
        <result column="is_delete" property="isDelete" />
    </resultMap>

    <!-- 通用查询结果列 -->
    <sql id="Base_Column_List">
        license_id, version, createtime, license_name, company, is_delete
    </sql>

</mapper>
